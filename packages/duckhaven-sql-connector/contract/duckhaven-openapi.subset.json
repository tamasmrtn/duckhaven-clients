    "schemas": {
      "ColumnSchemaOut": {
        "description": "One result column's name and DuckDB logical type.\n\n``type`` is spelled the way DuckDB itself prints a logical type \u2014 the same\nstring ``DESCRIBE`` returns in its ``column_type`` column. That spelling is\nself-describing and re-parses exactly, including parameterized and nested\ntypes (``DECIMAL(38,10)``, ``STRUCT(a INTEGER, b VARCHAR)``, ``ENUM('e', 'f')``,\n``INTEGER[2]``), so no separate precision/scale fields are carried.\n\nNo ``nullable`` field: DuckDB relations carry no reliable nullability\n(``DESCRIBE`` reports ``YES`` unconditionally), so reporting it would be\ninventing data.",
        "properties": {
          "name": {
            "title": "Name",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": [
          "name",
          "type"
        ],
        "title": "ColumnSchemaOut",
        "type": "object"
      },
